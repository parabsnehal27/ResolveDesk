@model List<ResolveDesk.Models.Complaint>

<style>

    /* PAGE BACKGROUND */

    .page-bg {
        background-image: url('/images/bg.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: calc(100vh - 70px);
        padding: 60px;
    }

    /* TITLE */

    .page-title {
        text-align: center;
        font-size: 40px;
        font-weight: 600;
        margin-bottom: 50px;
        color: #1F2937;
    }

    /* GRID */

    .complaint-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap: 30px;
    }

    /* CARD */

    .complaint-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 12px 25px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        /* HOVER */

        .complaint-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 35px rgba(0,0,0,0.15);
        }

    /* TITLE */

    .complaint-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    /* CATEGORY */

    .category {
        color: #6B7280;
        font-size: 14px;
        margin-bottom: 10px;
    }

    /* STATUS */

    .status {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
    }

    /* STATUS COLORS */

    .pending {
        background: #FEF3C7;
        color: #B45309;
    }

    .resolved {
        background: #DCFCE7;
        color: #166534;
    }

    .rejected {
        background: #FEE2E2;
        color: #991B1B;
    }

    /* DATE */

    .date {
        font-size: 13px;
        color: #6B7280;
        margin-top: 15px;
    }

</style>



<div class="page-bg">

    <h1 class="page-title">My Complaints</h1>

    <div class="complaint-grid">

        @foreach (var complaint in Model)
        {

            <div class="complaint-card">

                <div class="complaint-title">
                    @complaint.Title
                </div>

                <div class="category">
                    Category: @complaint.Category
                </div>

                <div>
                    Status:

                    @if (complaint.Status == "Pending")
                    {
                        <span class="status pending">Pending</span>
                    }

                    @if (complaint.Status == "Resolved")
                    {
                        <span class="status resolved">Resolved</span>
                    }

                    @if (complaint.Status == "Rejected")
                    {
                        <span class="status rejected">Rejected</span>
                    }

                </div>

                <div class="date">
                    Submitted: @complaint.CreatedAt.ToString("dd MMM yyyy")
                </div>

            </div>

        }

    </div>

</div>