@model List<ResolveDesk.Models.User>

<style>

    .page-title {
        font-size: 35px;
        font-weight: 600;
        margin-bottom: 30px;
    }

    .table-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }

    /* BUTTONS */

    .btn-edit {
        background: #F97316;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
    }

    .btn-delete {
        background: #EF4444;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 6px;
    }

    /* ROLE BADGE */

    .role-admin {
        background: #DCFCE7;
        color: #166534;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 13px;
    }

    .role-student {
        background: #FEF3C7;
        color: #92400E;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 13px;
    }

</style>


<h2 class="page-title">Manage Users</h2>


<div class="table-card">

    <table class="table table-hover">

        <thead>

            <tr>

                <th>ID</th>

                <th>Name</th>

                <th>Email</th>

                <th>Role</th>

                <th>Action</th>

            </tr>

        </thead>


        <tbody>

            @foreach (var user in Model)
            {

                <tr>

                    <td>@user.Id</td>

                    <td>@user.Name</td>

                    <td>@user.Email</td>

                    <td>

                        @if (user.Role == "Admin")
                        {
                            <span class="role-admin">Admin</span>
                        }
                        else
                        {
                            <span class="role-student">Student</span>
                        }

                    </td>

                    <td>

                        <a href="/Admin/EditUser/@user.Id" class="btn btn-edit">
                            Edit
                        </a>

                        <a href="/Admin/DeleteUser/@user.Id"
                           class="btn btn-delete"
                           onclick="return confirm('Delete this user?')">
                            Delete
                        </a>

                    </td>

                </tr>

            }

        </tbody>

    </table>

</div>