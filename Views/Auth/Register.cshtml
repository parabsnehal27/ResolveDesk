@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>ResolveDesk Register</title>

    <style>

        /* PAGE */

        body {
            height: 100vh;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Segoe UI, sans-serif;
            background-image: linear-gradient( rgba(245,230,207,0.50), rgba(233,211,177,0.50), rgba(220,194,156,0.50) ), url('/images/bg.jpeg');
            background-size: cover;
            background-position: center;
        }

        /* CARD */

        .register-card {
            width: 380px;
            padding: 40px;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            box-shadow: 0 30px 50px rgba(0,0,0,0.12);
            text-align: center;
        }

        /* TITLE */

        .title {
            font-size: 26px;
            font-weight: 600;
            color: #1F2937;
            margin-bottom: 25px;
        }

        /* INPUT GROUP */

        .input-group {
            margin-bottom: 18px;
        }

        /* INPUT */

        input {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: 1px solid #F1F5F9;
            background: #FAFAF9;
            font-size: 15px;
            box-sizing: border-box;
        }

            /* INPUT FOCUS */

            input:focus {
                outline: none;
                border: 1px solid #F97316;
                box-shadow: 0 0 0 3px rgba(249,115,22,0.15);
            }

        /* BUTTON */

        .register-btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            box-sizing: border-box;
            background: linear-gradient( 135deg, #FDBA74, #F97316, #EA580C );
        }

            .register-btn:hover {
            opacity: 0.9;
        }

        /* FOOTER */

        .footer {
            margin-top: 20px;
            font-size: 14px;
            color: #6B7280;
        }

            .footer a {
                color: #F97316;
                font-weight: 600;
                text-decoration: none;
            }

    </style>

</head>

<body>

    <div class="register-card">

        <div class="title">
            ResolveDesk Register
        </div>

        <form method="post" asp-controller="Auth" asp-action="Register">

            <div class="input-group">
                <input type="text" name="Name" placeholder="Full Name" required />
            </div>

            <div class="input-group">
                <input type="email" name="Email" placeholder="Email" required />
            </div>

            <div class="input-group">
                <input type="password" name="Password" placeholder="Password" required />
            </div>

            <button class="register-btn">
                Register
            </button>

        </form>

        <div class="footer">
            Already have an account?
            <a href="/Auth/Login">Login</a>
        </div>

    </div>

</body>
</html>