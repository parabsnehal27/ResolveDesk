@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>ResolveDesk Login</title>

    <style>

        /* PAGE */

        body {
            height: 100vh;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: Segoe UI, sans-serif;
            background-image: linear-gradient( rgba(245,230,207,0.50), rgba(233,211,177,0.50), rgba(220,194,156,0.50) ), url('/images/bg.jpeg');
            background-size: cover;
            background-position: center;
        }

        /* ORANGE BLUR SHAPES 

        .bg-shape {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            filter: blur(120px);
            z-index: -1;
        }

        .shape1 {
            top: -150px;
            left: -150px;
            background: #FDBA74;
        }

        .shape2 {
            bottom: -150px;
            right: -150px;
            background: #F97316;
        }    */
               
        /* LOGIN CARD */

        .login-card {
            width: 380px;
            padding: 40px;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            box-shadow: 0 30px 50px rgba(0,0,0,0.12);
            text-align: center;
        }

        /* TITLE */

        .login-title {
            font-size: 26px;
            font-weight: 600;
            color: #1F2937;
            margin-bottom: 25px;
        }

        /* INPUTS */
        .input-group {
            margin-bottom: 18px;
        }

        input {
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            border: 1px solid #F1F5F9;
            background: #FAFAF9;
            font-size: 15px;
            box-sizing: border-box;
        }

        /* LOGIN BUTTON */

        .login-btn {
            width: 100%;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            color: white;
            cursor: pointer;
            box-sizing: border-box;
            background: linear-gradient( 135deg, #FDBA74, #F97316, #EA580C );
        }

            .login-btn:hover {
                opacity: 0.9;
            }

        /* FOOTER */

        .footer {
            margin-top: 20px;
            font-size: 14px;
            color: #6B7280;
        }

            .footer a {
                color: #F97316;
                font-weight: 600;
                text-decoration: none;
            }

    </style>

</head>

<body>
  
    <div class="bg-shape shape1"></div>
    <div class="bg-shape shape2"></div>

    <div class="login-card">

        <div class="login-title">
            ResolveDesk Login
        </div>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }
        <br />
        <form method="post" asp-controller="Auth" asp-action="Login">

            <div class="input-group">
                <input type="email" name="Email" placeholder="Email" required />
            </div>

            <div class="input-group">
                <input type="password" name="Password" placeholder="Password" required />
            </div>
            
            <button class="login-btn">
                Sign In
            </button>

        </form>

        <div class="footer">
            Don't have an account?
            <a href="/Auth/Register">Register</a>
        </div>

    </div>

</body>
</html>